generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Authentication Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?   // For credentials auth
  firstName     String?
  lastName      String?
  company       String?   // Nombre de la empresa
  jobTitle      String?   // Cargo en la empresa
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  isActive      Boolean   @default(true)
  failedLoginAttempts Int @default(0)
  lockedUntil   DateTime?
  credits       Int       @default(0)  // User credit balance
  themePreference String  @default("light") // light, dark, system
  language      String    @default("es") // es, en - User's preferred language
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  creditTransactions CreditTransaction[] @relation("UserCreditTransactions")
  createdTransactions CreditTransaction[] @relation("CreditTransactionCreator")
  evaluations   DiscEvaluation[]
  responses     DiscResponse[]
  results       DiscResult[]
  sentExternalEvaluations ExternalEvaluation[]
  
  // Driving Forces Relations
  drivingForcesEvaluations DrivingForcesEvaluation[]
  drivingForcesResponses   DrivingForcesResponse[]
  drivingForcesResults     DrivingForcesResult[]
  sentExternalDrivingForcesEvaluations ExternalDrivingForcesEvaluation[]
  
  // Emotional Intelligence (EQ) Relations
  eqEvaluations            EQEvaluation[]
  eqResponses              EQResponse[]
  eqResults                EQResult[]
  sentExternalEQEvaluations ExternalEQEvaluation[]
  
  // DNA-25 Competencies Relations
  dnaEvaluations           DNAEvaluation[]
  dnaResponses             DNAResponse[]
  dnaResults               DNAResult[]
  sentExternalDNAEvaluations ExternalDNAEvaluation[]
  
  // Acumen (ACI) Relations
  acumenEvaluations        AcumenEvaluation[]
  acumenResponses          AcumenResponse[]
  acumenResults            AcumenResult[]
  sentExternalAcumenEvaluations ExternalAcumenEvaluation[]
  
  // Values & Integrity Relations
  valuesEvaluations        ValuesEvaluation[]
  valuesResponses          ValuesResponse[]
  valuesResults            ValuesResult[]
  sentExternalValuesEvaluations ExternalValuesEvaluation[]
  
  // Stress & Resilience Relations
  stressEvaluations        StressEvaluation[]
  stressResponses          StressResponse[]
  stressResults            StressResult[]
  sentExternalStressEvaluations ExternalStressEvaluation[]
  
  // Technical Evaluations Relations
  sentExternalTechnicalEvaluations ExternalTechnicalEvaluation[]
  technicalQuestionTemplates TechnicalQuestionTemplate[]
  
  // Notifications
  notifications            Notification[]
  
  // Evaluation Notes
  evaluationNotes          EvaluationNote[]
  
  // Credit Purchases
  creditPurchases          CreditPurchase[]
  
  // Selection Campaigns
  selectionCampaigns       SelectionCampaign[] @relation("UserCampaigns")
  
  // Team Management - As owner
  teamMembers              TeamMember[] @relation("TeamOwner")
  // Team Management - As facilitator (member of someone's team)
  memberOf                 TeamMember? @relation("TeamFacilitator")
  ownerId                  String?     // If this user is a facilitator, this is the owner's ID
  owner                    User?       @relation("OwnerRelation", fields: [ownerId], references: [id])
  facilitators             User[]      @relation("OwnerRelation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

// DISC System Models
model DiscQuestion {
  id          String        @id @default(cuid())
  questionNumber Int        @unique
  questionText String       @db.Text
  questionType QuestionType @default(ADJECTIVE)
  context     String?       // Work, Personal, etc.
  
  // Options for the question
  optionA     String        // Dominance option
  optionB     String        // Influence option  
  optionC     String        // Steadiness option
  optionD     String        // Conscientiousness option
  
  // Weights for scoring (if needed for advanced scoring)
  weightD     Float         @default(1.0)
  weightI     Float         @default(1.0)
  weightS     Float         @default(1.0)
  weightC     Float         @default(1.0)
  
  isActive    Boolean       @default(true)
  
  // Relations
  responses   DiscResponse[]
  externalResponses ExternalEvaluationResponse[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("disc_questions")
}

model DiscEvaluation {
  id          String            @id @default(cuid())
  title       String
  description String?           @db.Text
  userId      String
  status      EvaluationStatus  @default(DRAFT)
  
  // Evaluation metadata
  startedAt   DateTime?
  completedAt DateTime?
  isPublic    Boolean           @default(false)
  
  // Relations
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses   DiscResponse[]
  results     DiscResult[]
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("disc_evaluations")
}

model DiscResponse {
  id            String         @id @default(cuid())
  userId        String
  evaluationId  String
  questionId    String
  questionNumber Int
  
  // Response data
  selectedOption DiscDimension  // A=D, B=I, C=S, D=C
  responseTime   Int?           // Time in seconds to answer
  
  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation    DiscEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  question      DiscQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([userId, evaluationId, questionId])
  @@map("disc_responses")
}

model DiscResult {
  id           String         @id @default(cuid())
  userId       String
  evaluationId String
  
  // Raw scores (0-24 for 24 questions)
  scoreD       Int            @default(0)
  scoreI       Int            @default(0) 
  scoreS       Int            @default(0)
  scoreC       Int            @default(0)
  
  // Normalized scores (0-100)
  percentileD  Float          @default(0)
  percentileI  Float          @default(0)
  percentileS  Float          @default(0)
  percentileC  Float          @default(0)
  
  // Primary and secondary styles
  primaryStyle   DiscDimension
  secondaryStyle DiscDimension?
  personalityType String       // e.g., "DI", "SC", etc.
  
  // Style intensity
  styleIntensity Float         @default(0) // 0-100
  
  // Pattern flags
  isOvershift    Boolean       @default(false)
  isUndershift   Boolean       @default(false)
  isTightPattern Boolean       @default(false)
  
  // Relations
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation   DiscEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  interpretation DiscInterpretation?
  
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([userId, evaluationId])
  @@map("disc_results")
}

model DiscInterpretation {
  id              String     @id @default(cuid())
  resultId        String     @unique
  personalityType String     // "D", "I", "S", "C", "DI", "DC", etc.
  
  // Main interpretation content
  title           String
  description     String     @db.Text
  strengths       String[]   // Array of strengths
  challenges      String[]   // Array of challenges  
  motivators      String[]   // What motivates this type
  stressors       String[]   // What causes stress
  
  // Work style information
  workStyle       String     @db.Text
  communicationStyle String  @db.Text
  leadershipStyle String?    @db.Text
  teamRole        String?    @db.Text
  
  // Development recommendations
  developmentTips String[]   // Growth areas
  careerSuggestions String[] // Career paths
  
  // Relations
  result          DiscResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("disc_interpretations")
}

// Enums
enum UserRole {
  USER
  ADMIN
  FACILITATOR
}

enum QuestionType {
  ADJECTIVE    // Word-based questions
  SCENARIO     // Situation-based questions
  RANKING      // Rank order questions
}

enum EvaluationStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum DiscDimension {
  D  // Dominance
  I  // Influence  
  S  // Steadiness
  C  // Conscientiousness
}

// External Evaluations Models
model ExternalEvaluation {
  id              String    @id @default(cuid())
  title           String
  description     String?   @db.Text
  recipientName   String
  recipientEmail  String
  senderUserId    String
  token           String    @unique
  tokenExpiry     DateTime
  status          String    @default("PENDING") // PENDING, COMPLETED, EXPIRED
  
  // Relations
  senderUser      User      @relation(fields: [senderUserId], references: [id], onDelete: Restrict)
  responses       ExternalEvaluationResponse[]
  result          ExternalEvaluationResult?
  
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@map("external_evaluations")
}

model ExternalEvaluationResponse {
  id                     String             @id @default(cuid())
  externalEvaluationId   String
  questionId             String
  mostValue              Int                // 1-4 representing the option chosen as MOST
  leastValue             Int                // 1-4 representing the option chosen as LEAST
  
  // Relations
  externalEvaluation     ExternalEvaluation @relation(fields: [externalEvaluationId], references: [id], onDelete: Restrict)
  question               DiscQuestion       @relation(fields: [questionId], references: [id], onDelete: Restrict)
  
  createdAt              DateTime           @default(now())

  @@map("external_evaluation_responses")
}

model ExternalEvaluationResult {
  id                     String             @id @default(cuid())
  externalEvaluationId   String             @unique
  
  // DISC Results
  personalityType        String
  primaryStyle           String
  secondaryStyle         String?
  styleIntensity         Float
  percentileD            Float
  percentileI            Float
  percentileS            Float
  percentileC            Float
  
  // Pattern flags
  isOvershift            Boolean            @default(false)
  isUndershift           Boolean            @default(false)
  isTightPattern         Boolean            @default(false)
  
  // Relations
  externalEvaluation     ExternalEvaluation @relation(fields: [externalEvaluationId], references: [id], onDelete: Restrict)
  
  createdAt              DateTime           @default(now())

  @@map("external_evaluation_results")
}

// Driving Forces Models
model DrivingForcesQuestion {
  id          String        @id @default(cuid())
  questionNumber Int        @unique
  questionText String       @db.Text
  questionType DrivingForcesQuestionType @default(RANKING)
  
  // Statement options for ranking (1 = Most like me, 4 = Least like me)
  statementA  String        @db.Text  // Statement for first driving force
  statementB  String        @db.Text  // Statement for second driving force
  statementC  String        @db.Text  // Statement for third driving force
  statementD  String        @db.Text  // Statement for fourth driving force
  
  // Which driving force each statement represents
  forceA      DrivingForce
  forceB      DrivingForce
  forceC      DrivingForce
  forceD      DrivingForce
  
  isActive    Boolean       @default(true)
  category    String?       // Optional category grouping
  
  // Relations
  responses   DrivingForcesResponse[]
  externalResponses ExternalDrivingForcesResponse[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("driving_forces_questions")
}

model DrivingForcesEvaluation {
  id          String            @id @default(cuid())
  title       String
  description String?           @db.Text
  userId      String
  status      EvaluationStatus  @default(DRAFT)
  
  // Evaluation metadata
  startedAt   DateTime?
  completedAt DateTime?
  isPublic    Boolean           @default(false)
  
  // Relations
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses   DrivingForcesResponse[]
  results     DrivingForcesResult[]
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("driving_forces_evaluations")
}

model DrivingForcesResponse {
  id            String         @id @default(cuid())
  userId        String
  evaluationId  String
  questionId    String
  questionNumber Int
  
  // Response data - ranking from 1 (Most like me) to 4 (Least like me)
  rankingA      Int            // Ranking for statement A (1-4)
  rankingB      Int            // Ranking for statement B (1-4)
  rankingC      Int            // Ranking for statement C (1-4)
  rankingD      Int            // Ranking for statement D (1-4)
  responseTime  Int?           // Time in seconds to answer
  
  // Relations
  user          User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation    DrivingForcesEvaluation   @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  question      DrivingForcesQuestion     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([userId, evaluationId, questionId])
  @@map("driving_forces_responses")
}

model DrivingForcesResult {
  id           String         @id @default(cuid())
  userId       String
  evaluationId String
  
  // Raw scores for each driving force (sum of rankings, lower = stronger)
  intelectualScore     Int    @default(0)
  instintivoScore      Int    @default(0)
  practicoScore        Int    @default(0)
  altruistaScore       Int    @default(0)
  armoniosoScore       Int    @default(0)
  objetivoScore        Int    @default(0)
  benevoloScore        Int    @default(0)
  intencionalScore     Int    @default(0)
  dominanteScore       Int    @default(0)
  colaborativoScore    Int    @default(0)
  estructuradoScore    Int    @default(0)
  receptivoScore       Int    @default(0)
  
  // Normalized scores (0-100, higher = stronger)
  intelectualPercentile    Float  @default(0)
  instintivoPercentile     Float  @default(0)
  practicoPercentile       Float  @default(0)
  altruistaPercentile      Float  @default(0)
  armoniosoPercentile      Float  @default(0)
  objetivoPercentile       Float  @default(0)
  benevoloPercentile       Float  @default(0)
  intencionalPercentile    Float  @default(0)
  dominantePercentile      Float  @default(0)
  colaborativoPercentile   Float  @default(0)
  estructuradoPercentile   Float  @default(0)
  receptivoPercentile      Float  @default(0)
  
  // Primary motivators (top 4)
  primaryMotivators       String[]   // Array of top motivators
  situationalMotivators   String[]   // Array of middle motivators  
  indifferentMotivators   String[]   // Array of bottom motivators
  
  // Motivational clusters
  topMotivator       DrivingForce
  secondMotivator    DrivingForce?
  thirdMotivator     DrivingForce?
  fourthMotivator    DrivingForce?
  
  // Relations
  user         User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation   DrivingForcesEvaluation   @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  interpretation DrivingForcesInterpretation?
  
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([userId, evaluationId])
  @@map("driving_forces_results")
}

model DrivingForcesInterpretation {
  id              String     @id @default(cuid())
  resultId        String     @unique
  motivationalProfile String // e.g., "Intellectual-Resourceful", etc.
  
  // Main interpretation content
  title           String
  description     String     @db.Text
  strengths       String[]   // Array of motivational strengths
  challenges      String[]   // Array of motivational challenges  
  energizers      String[]   // What energizes this person
  stressors       String[]   // What causes motivational stress
  
  // Work environment preferences
  idealEnvironment String    @db.Text
  workPreferences  String    @db.Text
  avoidanceAreas   String[]  // Areas/situations to avoid
  
  // Development recommendations
  developmentTips String[]   // Motivational growth areas
  careerAlignment String[]   // Career paths that align with motivators
  
  // Relations
  result          DrivingForcesResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("driving_forces_interpretations")
}

// Additional Enums for Driving Forces
enum DrivingForcesQuestionType {
  RANKING      // Rank statements from most to least like you
  SCENARIO     // Situation-based questions
  FORCED_CHOICE // Choose between options
}

enum DrivingForce {
  INTELECTUAL     // Motivado por oportunidades de aprender
  INSTINTIVO      // Usa experiencias pasadas e intuición
  PRACTICO        // Resultados prácticos y eficiencia
  ALTRUISTA       // Completar tareas sin expectativa de retorno
  ARMONIOSO       // Experiencia y equilibrio en el entorno
  OBJETIVO        // Funcionalidad y objetividad
  BENEVOLO        // Ayudar a otros por satisfacción personal
  INTENCIONAL     // Ayudar a otros con propósito específico
  DOMINANTE       // Estatus, reconocimiento y control
  COLABORATIVO    // Rol de apoyo con poca necesidad de reconocimiento
  ESTRUCTURADO    // Enfoques tradicionales y métodos probados
  RECEPTIVO       // Nuevas ideas y oportunidades fuera del sistema definido
}

// External Driving Forces Evaluations Models
model ExternalDrivingForcesEvaluation {
  id              String    @id @default(cuid())
  title           String
  description     String?   @db.Text
  recipientName   String
  recipientEmail  String
  senderUserId    String
  token           String    @unique
  tokenExpiry     DateTime
  status          String    @default("PENDING") // PENDING, COMPLETED, EXPIRED
  
  // Relations
  senderUser      User      @relation(fields: [senderUserId], references: [id], onDelete: Restrict)
  responses       ExternalDrivingForcesResponse[]
  result          ExternalDrivingForcesResult?
  
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@map("external_driving_forces_evaluations")
}

model ExternalDrivingForcesResponse {
  id                           String                          @id @default(cuid())
  externalEvaluationId         String
  questionId                   String
  rankingA                     Int                             // Ranking para statement A (1-4)
  rankingB                     Int                             // Ranking para statement B (1-4)
  rankingC                     Int                             // Ranking para statement C (1-4)
  rankingD                     Int                             // Ranking para statement D (1-4)
  
  // Relations
  externalEvaluation           ExternalDrivingForcesEvaluation @relation(fields: [externalEvaluationId], references: [id], onDelete: Restrict)
  question                     DrivingForcesQuestion           @relation(fields: [questionId], references: [id], onDelete: Restrict)
  
  createdAt                    DateTime                        @default(now())

  @@unique([externalEvaluationId, questionId])
  @@map("external_driving_forces_responses")
}

model ExternalDrivingForcesResult {
  id                           String                          @id @default(cuid())
  externalEvaluationId         String                          @unique
  
  // Driving Forces Results
  motivationalProfile          String
  primaryMotivators            String[]  // Top 4 motivators
  situationalMotivators        String[]  // Middle motivators
  indifferentMotivators        String[]  // Bottom motivators
  
  topMotivator                 String
  secondMotivator              String?
  thirdMotivator               String?
  fourthMotivator              String?
  
  // Percentiles for each driving force
  intelectualPercentile        Float
  instintivoPercentile         Float
  practicoPercentile           Float
  altruistaPercentile          Float
  armoniosoPercentile          Float
  objetivoPercentile           Float
  benevoloPercentile           Float
  intencionalPercentile        Float
  dominantePercentile          Float
  colaborativoPercentile       Float
  estructuradoPercentile       Float
  receptivoPercentile          Float
  
  // Relations
  externalEvaluation           ExternalDrivingForcesEvaluation @relation(fields: [externalEvaluationId], references: [id], onDelete: Restrict)
  
  createdAt                    DateTime                        @default(now())

  @@map("external_driving_forces_results")
}

// =====================================================
// EMOTIONAL INTELLIGENCE (EQ) MODELS
// =====================================================

model EQQuestion {
  id              String        @id @default(cuid())
  questionNumber  Int           @unique
  questionText    String        @db.Text
  questionType    EQQuestionType @default(SCENARIO)
  
  // The EQ dimension this question measures
  dimension       EQDimension
  subdimension    String?       // e.g., "Emotional Self-Awareness", "Self-Confidence"
  
  // Options for Likert scale (1-5) or scenario-based
  optionA         String        @db.Text  // Strongly Disagree / Low EQ response
  optionB         String        @db.Text  // Disagree
  optionC         String        @db.Text  // Neutral
  optionD         String        @db.Text  // Agree
  optionE         String        @db.Text  // Strongly Agree / High EQ response
  
  // Scoring direction (some questions are reverse-scored)
  isReversed      Boolean       @default(false)
  weight          Float         @default(1.0)
  
  isActive        Boolean       @default(true)
  category        String?       // Optional category grouping
  
  // Relations
  responses       EQResponse[]
  externalResponses ExternalEQResponse[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("eq_questions")
}

model EQEvaluation {
  id          String            @id @default(cuid())
  title       String
  description String?           @db.Text
  userId      String
  status      EvaluationStatus  @default(DRAFT)
  
  // Evaluation metadata
  startedAt   DateTime?
  completedAt DateTime?
  isPublic    Boolean           @default(false)
  
  // Relations
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses   EQResponse[]
  results     EQResult[]
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("eq_evaluations")
}

model EQResponse {
  id            String         @id @default(cuid())
  userId        String
  evaluationId  String
  questionId    String
  questionNumber Int
  
  // Response data (1-5 Likert scale)
  selectedValue Int            // 1-5 scale
  responseTime  Int?           // Time in seconds to answer
  
  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation    EQEvaluation   @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  question      EQQuestion     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([userId, evaluationId, questionId])
  @@map("eq_responses")
}

model EQResult {
  id           String         @id @default(cuid())
  userId       String
  evaluationId String
  
  // Raw scores for each dimension (sum of responses)
  selfAwarenessScore      Int    @default(0)
  selfRegulationScore     Int    @default(0)
  motivationScore         Int    @default(0)
  empathyScore            Int    @default(0)
  socialSkillsScore       Int    @default(0)
  
  // Normalized scores (0-100)
  selfAwarenessPercentile    Float  @default(0)
  selfRegulationPercentile   Float  @default(0)
  motivationPercentile       Float  @default(0)
  empathyPercentile          Float  @default(0)
  socialSkillsPercentile     Float  @default(0)
  
  // Overall EQ score
  totalEQScore               Float  @default(0)
  totalEQPercentile          Float  @default(0)
  
  // Subdimension scores (15 subdimensions)
  emotionalSelfAwarenessScore    Float  @default(0)
  accurateSelfAssessmentScore    Float  @default(0)
  selfConfidenceScore            Float  @default(0)
  selfControlScore               Float  @default(0)
  trustworthinessScore           Float  @default(0)
  conscientiousnessScore         Float  @default(0)
  adaptabilityScore              Float  @default(0)
  innovationScore                Float  @default(0)
  achievementDriveScore          Float  @default(0)
  commitmentScore                Float  @default(0)
  initiativeScore                Float  @default(0)
  optimismScore                  Float  @default(0)
  understandingOthersScore       Float  @default(0)
  developingOthersScore          Float  @default(0)
  serviceOrientationScore        Float  @default(0)
  leveragingDiversityScore       Float  @default(0)
  politicalAwarenessScore        Float  @default(0)
  influenceScore                 Float  @default(0)
  communicationScore             Float  @default(0)
  conflictManagementScore        Float  @default(0)
  leadershipScore                Float  @default(0)
  changeManagementScore          Float  @default(0)
  buildingBondsScore             Float  @default(0)
  teamworkScore                  Float  @default(0)
  collaborationScore             Float  @default(0)
  
  // Primary strengths and development areas
  primaryStrengths       String[]  // Top 3 dimensions
  developmentAreas       String[]  // Bottom 2 dimensions
  
  // EQ Level classification
  eqLevel               String     // Very High, High, Moderate, Low, Very Low
  
  // Relations
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation   EQEvaluation   @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  interpretation EQInterpretation?
  
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([userId, evaluationId])

model ExternalValuesEvaluation {
  id              String    @id @default(cuid())
  title           String    @default("Evaluación de Valores")
  description     String?   @db.Text
  recipientName   String
  recipientEmail  String
  senderUserId    String
  token           String    @unique
  tokenExpiry     DateTime
  status          String    @default("PENDING") // PENDING, COMPLETED, EXPIRED
  
  // Relations
  senderUser      User      @relation(fields: [senderUserId], references: [id], onDelete: Restrict)
  responses       ExternalValuesResponse[]
  result          ExternalValuesResult?
  
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@map("external_values_evaluations")
}

model ExternalValuesResponse {
  id                     String                     @id @default(cuid())
  externalEvaluationId   String
  questionId             String
  questionNumber         Int
  
  selectedValue          Int
  secondaryValue         Int?
  responseTime           Int?
  
  externalEvaluation     ExternalValuesEvaluation   @relation(fields: [externalEvaluationId], references: [id], onDelete: Cascade)
  question               ValuesQuestion             @relation(fields: [questionId], references: [id], onDelete: Restrict)
  
  createdAt              DateTime                   @default(now())

  @@unique([externalEvaluationId, questionId])
  @@map("external_values_responses")
}

model ExternalValuesResult {
  id                     String                     @id @default(cuid())
  externalEvaluationId   String                     @unique
  
  // 6 Values Dimensions Scores
  teoricoScore           Float
  utilitarioScore        Float
  esteticoScore          Float
  socialScore            Float
  individualistaScore    Float
  tradicionalScore       Float
  
  // Integrity Indicators
  integrityScore         Float
  consistencyScore       Float
  authenticityScore      Float
  
  // Aggregates
  totalValuesScore       Float
  
  valuesLevel            String
  valuesProfile          String
  
  primaryValues          String[]
  situationalValues      String[]
  indifferentValues      String[]
  
  primaryStrengths       String[]
  developmentAreas       String[]
  
  externalEvaluation     ExternalValuesEvaluation @relation(fields: [externalEvaluationId], references: [id], onDelete: Restrict)
  
  createdAt              DateTime                 @default(now())

  @@map("external_values_results")
}

// Values Enums
enum ValuesQuestionType {
  RANKING      // Paired comparison/ranking questions
  SCENARIO     // Situation-based questions
  FORCED       // Forced choice questions
}

enum ValuesCategory {
  PERSONAL      // Personal life values
  PROFESSIONAL  // Professional/work values
}

enum ValuesDimension {
  TEORICO         // Theoretical - Knowledge seeking
  UTILITARIO      // Utilitarian - ROI focused
  ESTETICO        // Aesthetic - Form and harmony
  SOCIAL          // Social - Helping others
  INDIVIDUALISTA  // Individualistic - Power and control
  TRADICIONAL     // Traditional - Order and system
}

// ===========================================
// STRESS & RESILIENCE MODELS
// ===========================================

model StressQuestion {
  id              String              @id @default(cuid())
  questionNumber  Int                 @unique
  questionText    String              @db.Text
  questionType    StressQuestionType  @default(LIKERT)
  
  // The dimension this question measures
  dimension       StressDimension
  category        StressCategory      // Positive or Negative indicator
  
  // Options for Likert scale (1-5)
  optionA         String              @db.Text  // 1 - Nunca/Totalmente en desacuerdo
  optionB         String              @db.Text  // 2 - Raramente/En desacuerdo
  optionC         String              @db.Text  // 3 - A veces/Neutral
  optionD         String              @db.Text  // 4 - Frecuentemente/De acuerdo
  optionE         String              @db.Text  // 5 - Siempre/Totalmente de acuerdo
  
  // Scoring
  isReversed      Boolean             @default(false)
  weight          Float               @default(1.0)
  isActive        Boolean             @default(true)
  
  // Relations
  responses       StressResponse[]
  externalResponses ExternalStressResponse[]
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("stress_questions")
}

model StressEvaluation {
  id          String            @id @default(cuid())
  title       String
  description String?           @db.Text
  userId      String
  status      EvaluationStatus  @default(DRAFT)
  
  startedAt   DateTime?
  completedAt DateTime?
  isPublic    Boolean           @default(false)
  
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses   StressResponse[]
  results     StressResult[]
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("stress_evaluations")
}

model StressResponse {
  id            String              @id @default(cuid())
  userId        String
  evaluationId  String
  questionId    String
  questionNumber Int
  
  // Response: Likert value 1-5
  selectedValue Int
  responseTime  Int?
  
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation    StressEvaluation    @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  question      StressQuestion      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([userId, evaluationId, questionId])
  @@map("stress_responses")
}

model StressResult {
  id           String              @id @default(cuid())
  userId       String
  evaluationId String
  
  // 5 Stress Dimensions Scores (0-100 percentile)
  estresLaboralScore        Float   @default(0)   // Work Stress
  capacidadRecuperacionScore Float  @default(0)   // Recovery Capacity
  manejoEmocionalScore      Float   @default(0)   // Emotional Management
  equilibrioVidaScore       Float   @default(0)   // Work-Life Balance
  resilienciaScore          Float   @default(0)   // Resilience
  
  // Overall Indicators
  nivelEstresGeneral        Float   @default(0)   // Overall stress level (lower is better)
  indiceResiliencia         Float   @default(0)   // Resilience index (higher is better)
  capacidadAdaptacion       Float   @default(0)   // Adaptation capacity
  
  // Aggregate scores
  totalStressScore          Float   @default(0)
  
  // Level classification
  stressLevel               String                  // Muy Bajo, Bajo, Moderado, Alto, Muy Alto
  resilienceLevel           String                  // Muy Alta, Alta, Moderada, Baja, Muy Baja
  stressProfile             String                  // Profile description
  
  // Risk and protective factors
  riskFactors               String[]                // Identified risk factors
  protectiveFactors         String[]                // Identified protective factors
  
  // Strengths and areas for development
  primaryStrengths          String[]
  developmentAreas          String[]
  
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation    StressEvaluation    @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([userId, evaluationId])
  @@map("stress_results")
}

// External Stress Evaluation (sent to external users)
model ExternalStressEvaluation {
  id              String    @id @default(cuid())
  title           String    @default("Evaluación de Estrés y Resiliencia")
  description     String?   @db.Text
  recipientName   String
  recipientEmail  String
  senderUserId    String
  token           String    @unique
  tokenExpiry     DateTime
  status          String    @default("PENDING") // PENDING, COMPLETED, EXPIRED
  
  // Relations
  senderUser      User      @relation(fields: [senderUserId], references: [id], onDelete: Restrict)
  responses       ExternalStressResponse[]
  result          ExternalStressResult?
  
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@map("external_stress_evaluations")
}

model ExternalStressResponse {
  id                     String                     @id @default(cuid())
  externalEvaluationId   String
  questionId             String
  questionNumber         Int
  
  selectedValue          Int
  responseTime           Int?
  
  externalEvaluation     ExternalStressEvaluation   @relation(fields: [externalEvaluationId], references: [id], onDelete: Cascade)
  question               StressQuestion             @relation(fields: [questionId], references: [id], onDelete: Restrict)
  
  createdAt              DateTime                   @default(now())

  @@unique([externalEvaluationId, questionId])
  @@map("external_stress_responses")
}

model ExternalStressResult {
  id                     String                     @id @default(cuid())
  externalEvaluationId   String                     @unique
  
  // 5 Stress Dimensions Scores
  estresLaboralScore         Float
  capacidadRecuperacionScore Float
  manejoEmocionalScore       Float
  equilibrioVidaScore        Float
  resilienciaScore           Float
  
  // Overall Indicators
  nivelEstresGeneral         Float
  indiceResiliencia          Float
  capacidadAdaptacion        Float
  
  // Aggregates
  totalStressScore           Float
  
  stressLevel                String
  resilienceLevel            String
  stressProfile              String
  
  riskFactors                String[]
  protectiveFactors          String[]
  
  primaryStrengths           String[]
  developmentAreas           String[]
  
  externalEvaluation     ExternalStressEvaluation @relation(fields: [externalEvaluationId], references: [id], onDelete: Restrict)
  
  createdAt              DateTime                 @default(now())

  @@map("external_stress_results")
}

// Stress Enums
enum StressQuestionType {
  LIKERT       // Agreement scale questions
  SCENARIO     // Situation-based questions
  FREQUENCY    // Frequency-based questions
}

enum StressCategory {
  POSITIVE     // Protective/resilience indicators
  NEGATIVE     // Risk/stress indicators
}

enum StressDimension {
  ESTRES_LABORAL          // Work-related stress
  CAPACIDAD_RECUPERACION  // Recovery capacity
  MANEJO_EMOCIONAL        // Emotional management
  EQUILIBRIO_VIDA         // Work-life balance
  RESILIENCIA             // General resilience
}

// ============================================
// Notifications Model
// ============================================
model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  read        Boolean          @default(false)
  
  // Link to the relevant resource
  evaluationType    EvaluationType?
  evaluationToken   String?
  recipientName     String?
  recipientEmail    String?
  
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  EVALUATION_COMPLETED
  EVALUATION_EXPIRED
  EVALUATION_REMINDER
  CREDIT_RECHARGE
  CREDITS_ZERO
  CREDITS_LOW
  SYSTEM
}

enum EvaluationType {
  DISC
  DRIVING_FORCES
  EQ
  DNA
  ACUMEN
  VALUES
  STRESS
  TECHNICAL
}

// System Settings
model SystemSettings {
  id            String    @id @default(cuid())
  key           String    @unique
  value         String
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("system_settings")
}

// Credit Transactions
model CreditTransaction {
  id            String    @id @default(cuid())
  userId        String
  amount        Int       // Positive for additions, negative for deductions
  type          CreditTransactionType
  description   String
  evaluationType EvaluationType?
  evaluationId  String?   // Reference to specific evaluation if applicable
  balanceAfter  Int       // Balance after this transaction
  createdBy     String?   // User who made the transaction (facilitator or admin)
  user          User      @relation("UserCreditTransactions", fields: [userId], references: [id], onDelete: Cascade)
  createdByUser User?     @relation("CreditTransactionCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("credit_transactions")
}

enum CreditTransactionType {
  INITIAL          // Initial credits on signup
  EVALUATION_SENT  // Credits used for sending evaluation
  RECHARGE         // Admin recharge
  ADJUSTMENT       // Manual adjustment
  PURCHASE         // Credits purchased via PayPal
}

// Credit Purchases via PayPal
model CreditPurchase {
  id              String              @id @default(cuid())
  userId          String
  creditAmount    Int                 // Number of credits purchased
  priceUSD        Float               // Total price in USD
  pricePerCredit  Float               // Price per credit at time of purchase
  paypalOrderId   String?             @unique  // PayPal order ID
  paypalPayerId   String?             // PayPal payer ID
  paypalPayerEmail String?            // PayPal payer email
  status          CreditPurchaseStatus @default(PENDING)
  invoiceNumber   String?             // Generated invoice number
  invoiceSentAt   DateTime?           // When invoice email was sent
  completedAt     DateTime?           // When payment was completed
  errorMessage    String?             // Error message if payment failed
  
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@index([userId, status])
  @@index([paypalOrderId])
  @@map("credit_purchases")
}

enum CreditPurchaseStatus {
  PENDING     // Order created, waiting for payment
  COMPLETED   // Payment successful, credits added
  FAILED      // Payment failed
  CANCELLED   // User cancelled payment
}

// ============================================
// Team/Facilitator Management
// ============================================
model TeamMember {
  id              String              @id @default(cuid())
  ownerId         String              // User who invited this team member
  
  // Invitation data
  email           String
  name            String
  jobTitle        String              // Cargo
  
  // Access control
  accessLevel     TeamAccessLevel     @default(OWN_EVALUATIONS)
  
  // Invitation status
  status          TeamInviteStatus    @default(PENDING)
  inviteToken     String              @unique
  tokenExpiry     DateTime
  
  // If accepted, link to the user account
  facilitatorId   String?             @unique
  facilitator     User?               @relation("TeamFacilitator", fields: [facilitatorId], references: [id], onDelete: SetNull)
  
  // Owner relation
  owner           User                @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  // Timestamps
  invitedAt       DateTime            @default(now())
  acceptedAt      DateTime?
  lastActiveAt    DateTime?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([ownerId, email])
  @@index([ownerId, status])
  @@index([inviteToken])
  @@map("team_members")
}

enum TeamAccessLevel {
  FULL_ACCESS      // Access to all company evaluations
  OWN_EVALUATIONS  // Access only to evaluations they create
}

enum TeamInviteStatus {
  PENDING          // Invitation sent, waiting for acceptance
  ACCEPTED         // Invitation accepted, user created account
  EXPIRED          // Token expired
  REVOKED          // Invitation revoked by owner
}

// ============================================
// Evaluation Notes/Comments
// ============================================
model EvaluationNote {
  id                String              @id @default(cuid())
  
  // The user who wrote the note
  authorId          String
  author            User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  // Evaluation reference (polymorphic - type + id)
  evaluationType    EvaluationType      // DISC, DRIVING_FORCES, EQ, DNA, ACUMEN, VALUES, STRESS
  evaluationId      String              // Token for external evaluations
  
  // Note content
  content           String              @db.Text
  
  // Metadata
  recipientEmail    String              // Email of the person being evaluated
  recipientName     String?             // Name of the person being evaluated
  
  // Timestamps
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([evaluationType, evaluationId])
  @@index([authorId, createdAt])
  @@index([recipientEmail])
  @@map("evaluation_notes")
}

// ============================================
// SELECTION CAMPAIGNS (Campañas de Selección)
// ============================================

model SelectionCampaign {
  id              String                @id @default(cuid())
  name            String                // Nombre de la campaña
  jobTitle        String                // Cargo para el que se busca
  jobCategory     String?               // Categoría del cargo
  description     String?               @db.Text
  campaignType    String                @default("SELECTION") // SELECTION | INTERNAL_TEAM
  
  // Owner of the campaign
  userId          String
  user            User                  @relation("UserCampaigns", fields: [userId], references: [id], onDelete: Cascade)
  
  // Campaign settings
  status          CampaignStatus        @default(ACTIVE)
  evaluationTypes String[]              // Array of evaluation types to send: ["DISC", "EQ", "DNA", etc.]
  technicalTemplateId String?           // Plantilla técnica seleccionada para esta campaña
  technicalTemplate   TechnicalQuestionTemplate? @relation("CampaignTechnicalTemplate", fields: [technicalTemplateId], references: [id], onDelete: SetNull)
  
  // Visibility & Permissions
  isPrivate             Boolean         @default(true)  // true = solo owner y full access, false = visible para todo el equipo
  allowTeamAddCandidates Boolean        @default(false) // true = cualquier miembro del equipo puede agregar candidatos
  
  // Analysis settings
  idealProfileWeights Json?             // Custom weights for ideal profile (optional)
  
  // Candidates
  candidates      CampaignCandidate[]
  
  // Completion data
  hiredCandidateId   String?               // ID of the hired/selected candidate
  hiredCandidateName String?               // Denormalized name for quick display
  completionNotes    String?               @db.Text // Notes: salary, start date, etc.
  archivedAt         DateTime?             // When campaign was archived
  
  // Timestamps
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  closedAt        DateTime?
  
  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("selection_campaigns")
}

model CampaignCandidate {
  id              String                @id @default(cuid())
  campaignId      String
  campaign        SelectionCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  // Candidate info
  name            String
  email           String
  phone           String?
  notes           String?               @db.Text
  
  // Status tracking
  status          CandidateStatus       @default(INVITED)
  
  // Linked evaluation tokens (for tracking which evaluations belong to this candidate)
  discToken       String?               // Token of DISC external evaluation
  drivingForcesToken String?            // Token of Driving Forces external evaluation
  eqToken         String?               // Token of EQ external evaluation
  dnaToken        String?               // Token of DNA external evaluation
  acumenToken     String?               // Token of Acumen external evaluation
  valuesToken     String?               // Token of Values external evaluation
  stressToken     String?               // Token of Stress external evaluation
  technicalToken  String?               // Token of Technical external evaluation
  
  // Analysis scores (calculated from completed evaluations)
  overallScore    Float?                // Calculated overall fit score (0-100)
  rankPosition    Int?                  // Position in campaign ranking
  analysisData    Json?                 // Detailed analysis data
  
  // Timestamps
  invitedAt       DateTime              @default(now())
  lastCompletedAt DateTime?             // When last evaluation was completed
  
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  
  @@unique([campaignId, email])
  @@index([campaignId, status])
  @@index([campaignId, overallScore])
  @@map("campaign_candidates")
}

enum CampaignStatus {
  DRAFT           // Campaign created but not active
  ACTIVE          // Campaign is active, candidates can be added
  EVALUATING      // All candidates invited, waiting for results
  ANALYZING       // All evaluations complete, analyzing results
  COMPLETED       // Analysis done, campaign closed
  ARCHIVED        // Campaign archived
}

enum CandidateStatus {
  INVITED         // Candidate has been invited
  EVALUATING      // Candidate is taking evaluations
  COMPLETED       // All evaluations completed
  WITHDRAWN       // Candidate withdrew or was removed
}


// =====================================================
// TECHNICAL EVALUATIONS (Pruebas Técnicas por Cargo)
// =====================================================

model TechnicalQuestion {
  id              String            @id @default(cuid())
  questionNumber  Int
  
  // Spanish text (primary)
  questionText    String            @db.Text
  optionA         String            @db.Text
  optionB         String            @db.Text
  optionC         String            @db.Text
  optionD         String            @db.Text
  
  // English text (multilingual support)
  questionTextEn  String?           @db.Text
  optionAEn       String?           @db.Text
  optionBEn       String?           @db.Text
  optionCEn       String?           @db.Text
  optionDEn       String?           @db.Text
  
  // Job position this question belongs to
  jobPositionId   String            // ID from job-positions.ts (e.g., "software_engineer", "accountant")
  
  // Correct answer (A, B, C, or D)
  correctAnswer   String
  
  // Difficulty level
  difficulty      TechnicalDifficulty @default(MEDIUM)
  
  // Category/topic within the job (bilingual)
  category        String?           // Spanish: e.g., "Programación", "Principios Contables"
  categoryEn      String?           // English: e.g., "Programming", "Accounting Principles"
  
  // Scoring weight
  weight          Float             @default(1.0)
  isActive        Boolean           @default(true)
  
  // Relations
  responses       ExternalTechnicalResponse[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([jobPositionId, questionNumber])
  @@index([jobPositionId, isActive])
  @@map("technical_questions")
}

model ExternalTechnicalEvaluation {
  id              String    @id @default(cuid())
  title           String
  description     String?   @db.Text
  recipientName   String
  recipientEmail  String
  senderUserId    String
  token           String    @unique
  tokenExpiry     DateTime
  status          String    @default("PENDING") // PENDING, COMPLETED, EXPIRED
  
  // Job position this evaluation is for
  jobPositionId   String
  jobPositionTitle String   // Store title for display
  technicalTemplateId String?
  technicalTemplate   TechnicalQuestionTemplate? @relation("ExternalTechnicalTemplate", fields: [technicalTemplateId], references: [id], onDelete: SetNull)
  questionSetConfig Json?    // Custom question set configuration and selected question IDs
  
  // Relations
  senderUser      User      @relation(fields: [senderUserId], references: [id], onDelete: Restrict)
  responses       ExternalTechnicalResponse[]
  result          ExternalTechnicalResult?
  
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([senderUserId, status])
  @@index([recipientEmail])
  @@index([jobPositionId])
  @@map("external_technical_evaluations")
}

model TechnicalQuestionTemplate {
  id               String   @id @default(cuid())
  name             String
  description      String?  @db.Text
  ownerUserId      String
  ownerUser        User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  basePositionId   String
  basePositionTitle String
  questionSetConfig Json

  campaigns        SelectionCampaign[] @relation("CampaignTechnicalTemplate")
  evaluations      ExternalTechnicalEvaluation[] @relation("ExternalTechnicalTemplate")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([ownerUserId, createdAt])
  @@index([basePositionId])
  @@map("technical_question_templates")
}

model ExternalTechnicalResponse {
  id                     String                      @id @default(cuid())
  externalEvaluationId   String
  questionId             String
  
  // Selected answer (A, B, C, or D)
  selectedAnswer         String
  
  // Was the answer correct?
  isCorrect              Boolean
  
  // Time taken to answer (in seconds)
  responseTime           Int?
  
  // Relations
  externalEvaluation     ExternalTechnicalEvaluation @relation(fields: [externalEvaluationId], references: [id], onDelete: Restrict)
  question               TechnicalQuestion           @relation(fields: [questionId], references: [id], onDelete: Restrict)
  
  createdAt              DateTime                    @default(now())

  @@unique([externalEvaluationId, questionId])
  @@map("external_technical_responses")
}

model ExternalTechnicalResult {
  id                     String                      @id @default(cuid())
  externalEvaluationId   String                      @unique
  
  // Overall score
  totalScore             Float                       // Percentage correct (0-100)
  correctAnswers         Int                         // Number of correct answers
  totalQuestions         Int                         // Total number of questions
  
  // Performance level
  performanceLevel       String                      // EXCELLENT, GOOD, AVERAGE, BELOW_AVERAGE, POOR
  
  // Category breakdown (JSON with scores per category)
  categoryScores         Json?                       // { "Category1": 85, "Category2": 70, ... }
  
  // Difficulty breakdown
  easyCorrect            Int?
  easyTotal              Int?
  mediumCorrect          Int?
  mediumTotal            Int?
  hardCorrect            Int?
  hardTotal              Int?
  
  // Time statistics
  totalTimeTaken         Int?                        // Total time in seconds
  averageTimePerQuestion Float?                      // Average time per question
  
  // Strengths and weaknesses
  strengths              String[]                    // Categories with high scores
  weaknesses             String[]                    // Categories with low scores
  
  // Relations
  externalEvaluation     ExternalTechnicalEvaluation @relation(fields: [externalEvaluationId], references: [id], onDelete: Restrict)
  
  createdAt              DateTime                    @default(now())

  @@map("external_technical_results")
}

enum TechnicalDifficulty {
  EASY
  MEDIUM
  HARD
}

// =====================================================

model AcumenQuestion {
  id              String            @id @default(cuid())
  questionNumber  Int               @unique
  questionText    String            @db.Text
  questionType    AcumenQuestionType @default(AGREEMENT)
  
  // The dimension this question measures
  dimension       AcumenDimension
  factor          AcumenFactor      // External or Internal
  
  // Options for 5-point scale (Nunca to Siempre)
  optionA         String            @db.Text
  optionB         String            @db.Text
  optionC         String?           @db.Text
  optionD         String?           @db.Text
  optionE         String?           @db.Text
  
  // Scoring
  isReversed      Boolean           @default(false)
  weight          Float             @default(1.0)
  isActive        Boolean           @default(true)
  
  // Relations
  responses       AcumenResponse[]
  externalResponses ExternalAcumenResponse[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("acumen_questions")
}

model AcumenEvaluation {
  id          String            @id @default(cuid())
  title       String
  description String?           @db.Text
  userId      String
  status      EvaluationStatus  @default(DRAFT)
  
  startedAt   DateTime?
  completedAt DateTime?
  isPublic    Boolean           @default(false)
  
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses   AcumenResponse[]
  results     AcumenResult[]
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("acumen_evaluations")
}

model AcumenResponse {
  id            String            @id @default(cuid())
  userId        String
  evaluationId  String
  questionId    String
  questionNumber Int
  
  // Response: ranking value or selection
  selectedValue Int               // Primary response value
  secondaryValue Int?             // For ranking comparisons
  responseTime  Int?
  
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation    AcumenEvaluation  @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  question      AcumenQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([userId, evaluationId, questionId])
  @@map("acumen_responses")
}

model AcumenResult {
  id           String            @id @default(cuid())
  userId       String
  evaluationId String
  
  // External Factors Clarity Scores (0-10 scale)
  understandingOthersClarity    Float   @default(0)
  practicalThinkingClarity      Float   @default(0)
  systemsJudgmentClarity        Float   @default(0)
  
  // Internal Factors Clarity Scores (0-10 scale)
  senseOfSelfClarity            Float   @default(0)
  roleAwarenessClarity          Float   @default(0)
  selfDirectionClarity          Float   @default(0)
  
  // Bias indicators (-1 undervalue, 0 neutral, 1 overvalue)
  understandingOthersBias       Int     @default(0)
  practicalThinkingBias         Int     @default(0)
  systemsJudgmentBias           Int     @default(0)
  senseOfSelfBias               Int     @default(0)
  roleAwarenessBias             Int     @default(0)
  selfDirectionBias             Int     @default(0)
  
  // Aggregate scores
  externalClarityScore          Float   @default(0)
  internalClarityScore          Float   @default(0)
  totalAcumenScore              Float   @default(0)
  
  // Level classification
  acumenLevel                   String  // Very High, High, Moderate, Low, Very Low
  acumenProfile                 String  // Profile description
  
  // Strengths and areas for development
  primaryStrengths              String[]
  developmentAreas              String[]
  
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation    AcumenEvaluation  @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([userId, evaluationId])
  @@map("acumen_results")
}

